"""SDK-first vertical definition for {{ name }} tasks."""

from __future__ import annotations

from victor_sdk import (
    CapabilityIds,
    CapabilityRequirement,
    StageDefinition,
    ToolNames,
    ToolRequirement,
    VerticalBase,
)


class {{ name_class }}Assistant(VerticalBase):
    """{{ name_title }} assistant definition authored against `victor_sdk`."""

    name = "{{ name }}"
    description = "{{ description }}"
    version = "1.0.0"

    @classmethod
    def get_name(cls) -> str:
        return cls.name

    @classmethod
    def get_description(cls) -> str:
        return cls.description

    @classmethod
    def get_tool_requirements(cls) -> list[ToolRequirement]:
        """Return typed tool requirements for {{ name }} workflows."""

        return [
            ToolRequirement(ToolNames.READ, purpose="inspect relevant files"),
            ToolRequirement(ToolNames.LS, purpose="understand repository structure"),
            ToolRequirement(
                ToolNames.GREP,
                purpose="locate exact patterns and identifiers",
            ),
            ToolRequirement(
                ToolNames.CODE_SEARCH,
                required=False,
                purpose="perform broader semantic exploration when available",
            ),
            ToolRequirement(
                ToolNames.WRITE,
                required=False,
                purpose="write notes, reports, or generated artifacts",
            ),
            ToolRequirement(
                ToolNames.SHELL,
                required=False,
                purpose="run verification or domain-specific commands",
            ),
        ]

    @classmethod
    def get_tools(cls) -> list[str]:
        """Compatibility bridge for integrations that still call `get_tools()`."""

        return [requirement.tool_name for requirement in cls.get_tool_requirements()]

    @classmethod
    def get_capability_requirements(cls) -> list[CapabilityRequirement]:
        """Declare runtime capabilities this vertical prefers."""

        return [
            CapabilityRequirement(
                capability_id=CapabilityIds.FILE_OPS,
                purpose="read and optionally write workspace files",
            ),
            CapabilityRequirement(
                capability_id=CapabilityIds.GIT,
                optional=True,
                purpose="inspect repository history or changes when useful",
            ),
        ]

    @classmethod
    def get_system_prompt(cls) -> str:
        """Return the system prompt for {{ name }} tasks."""

        return """You are Victor, an expert {{ name }} assistant.

Your capabilities:
- {{ description }}
- Careful repository and document analysis
- Safe, evidence-based changes and recommendations

Guidelines:
1. Understand the target before proposing changes.
2. Prefer read-first exploration before running commands.
3. Keep changes focused and explain non-obvious decisions.
4. Verify important conclusions with tool output.
5. Distinguish confirmed findings from follow-up suggestions.
"""

    @classmethod
    def get_prompt_templates(cls) -> dict[str, str]:
        """Return task-specific prompt templates for {{ name }} work."""

        return {
            "analysis": "Analyze the target carefully before making changes.",
            "implementation": "Implement the requested {{ name }} change and verify it.",
        }

    @classmethod
    def get_task_type_hints(cls) -> dict[str, dict[str, object]]:
        """Return task-type hints for {{ name }} workflows."""

        return {
            "analysis": {
                "hint": "Start with repository reconnaissance and summarize the key constraints.",
                "tool_budget": 8,
                "priority_tools": [ToolNames.READ, ToolNames.GREP, ToolNames.LS],
            },
            "implementation": {
                "hint": "Read the target first, then make focused changes and verify the result.",
                "tool_budget": 10,
                "priority_tools": [ToolNames.READ, ToolNames.WRITE, ToolNames.SHELL],
            },
        }

    @classmethod
    def get_stages(cls) -> dict[str, StageDefinition]:
        """Return declarative workflow stages for {{ name }} tasks."""

        return {
            "analysis": StageDefinition(
                name="analysis",
                description="Gather context and understand the target before acting.",
                required_tools=[ToolNames.READ, ToolNames.LS],
                optional_tools=[ToolNames.GREP, ToolNames.CODE_SEARCH],
            ),
            "execution": StageDefinition(
                name="execution",
                description="Apply focused changes or domain-specific actions.",
                required_tools=[ToolNames.READ],
                optional_tools=[ToolNames.WRITE, ToolNames.SHELL],
            ),
            "verification": StageDefinition(
                name="verification",
                description="Validate the result and summarize any residual risk.",
                required_tools=[ToolNames.READ],
                optional_tools=[ToolNames.SHELL],
            ),
        }

    @classmethod
    def get_initial_stage(cls) -> str:
        return "analysis"

    @classmethod
    def get_workflow_spec(cls) -> dict[str, object]:
        return {"stage_order": ["analysis", "execution", "verification"]}

    @classmethod
    def get_provider_hints(cls) -> dict[str, object]:
        """Return provider preferences for {{ name }} tasks."""

        return {
            "preferred_providers": ["anthropic", "openai"],
            "requires_tool_calling": True,
        }

    @classmethod
    def get_evaluation_criteria(cls) -> list[str]:
        """Return evaluation criteria for {{ name }} task quality."""

        return [
            "correctness",
            "clarity",
            "evidence_quality",
            "adherence_to_existing_patterns",
        ]
