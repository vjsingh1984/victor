{
  "dashboard": {
    "title": "Victor AI - Tool Registry Performance",
    "description": "Performance monitoring dashboard for tool registry operations",
    "tags": ["victor", "registry", "performance"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Operations Per Second",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(registry_operations_total{status=\"success\"}[1m])",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "ops",
            "label": "Operations / sec",
            "min": 0
          }
        ],
        "description": "Registry operation throughput"
      },
      {
        "id": 2,
        "title": "Operation Duration (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(registry_operation_duration_ms_bucket[1m]))",
            "legendFormat": "p50 - {{operation}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(registry_operation_duration_ms_bucket[1m]))",
            "legendFormat": "p95 - {{operation}}",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(registry_operation_duration_ms_bucket[1m]))",
            "legendFormat": "p99 - {{operation}}",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "format": "ms",
            "label": "Duration (ms)",
            "min": 0
          }
        ],
        "description": "Registry operation latency percentiles"
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(registry_operations_total{status=\"error\"}[1m]) / rate(registry_operations_total[1m]) * 100",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "label": "Error Rate (%)",
            "min": 0,
            "max": 100
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [5.0],
                "type": "gt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "1m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Error Rate Alert",
          "noDataState": "no_data",
          "notifications": []
        },
        "description": "Registry operation error rate (alerts if >5%)"
      },
      {
        "id": 4,
        "title": "Cache Size",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "registry_cache_size",
            "legendFormat": "{{cache_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Cache Size",
            "min": 0
          }
        ],
        "description": "Cache size by type"
      },
      {
        "id": 5,
        "title": "Cache Hit Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "registry_cache_hit_rate",
            "legendFormat": "{{cache_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "label": "Hit Rate (%)",
            "min": 0,
            "max": 100
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [50.0],
                "type": "lt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Cache Hit Rate Alert",
          "noDataState": "no_data",
          "notifications": []
        },
        "description": "Cache hit rate by type (alerts if <50%)"
      },
      {
        "id": 6,
        "title": "Slowest Operations",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "registry_operation_duration_ms_sum / registry_operation_duration_ms_count",
            "legendFormat": "{{operation}}",
            "refId": "A",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "sort",
            "options": {
              "byField": "Value",
              "dest": "asc"
            }
          }
        ],
        "description": "Average operation duration sorted by slowest"
      },
      {
        "id": 7,
        "title": "Performance Regression Detection",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "registry_operation_duration_ms_sum / registry_operation_duration_ms_count",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "ms",
            "label": "Duration (ms)",
            "min": 0
          }
        ],
        "description": "Track operation duration over time to detect regressions"
      }
    ]
  },
  "overwrite": true
}
